{
  "name": "norka-r35-scroll-story",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "inspect:model": "node scripts/inspect-model.mjs public/models/norka-r35-desktop.glb",
    "inspect:model:original": "node scripts/inspect-model.mjs public/models/norka-r35-original.glb",
    "optimize:model": "node scripts/optimize-model.mjs --variant desktop"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "gsap": "3.15.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1",
    "three-stdlib": "2.36.1"
  },
  "devDependencies": {
    "@gltf-transform/core": "4.4.1",
    "@gltf-transform/extensions": "4.4.1",
    "@gltf-transform/functions": "4.4.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "meshoptimizer": "1.2.0",
    "typescript": "7.0.2",
    "vite": "8.1.5"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "yarn@1.22.22"
}
